# .env.example
# Copy to .env or export these in your shell / CI environment.
# Never commit actual keys to version control.

# ── OpenRouter (REQUIRED for multi-LLM; optional for single-LLM) ───────────
# All committee models are accessed via OpenRouter's OpenAI-compatible API.
# OpenRouter can also be used for single-model runs.
# Create or find your key at: https://openrouter.ai/keys
# Alternatively create ~/.openrouter_key with just the key string.
OPENROUTER_API_KEY=sk-or-...


# ── Optional single-LLM direct-provider keys ────────────────────────────────
# These are used only when you choose single-LLM runs with Anthropic or OpenAI.
# The multi-LLM committee path does not use them.
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
